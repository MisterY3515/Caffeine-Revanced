/* Dim screen on lid close */
"Dim screen when lid is closed" = "Schermhelderheid op nul zetten als de klep gesloten is";
"Sets the screen brightness to zero when the lid is closed, restoring it when reopened." = "Zet de schermhelderheid op nul als de klep gesloten is en herstelt deze bij het openen.";

/* Dim keyboard backlight on lid close */
"Dim keyboard backlight when lid is closed" = "Toetsenbordachtergrondverlichting dimmen als de klep gesloten is";
"Dims the keyboard backlight to zero when the lid is closed, restoring it when reopened." = "Dimt de toetsenbordachtergrondverlichting naar nul als de klep gesloten is en herstelt deze bij het openen.";

/* AC power activation */
"Activate when connected to power" = "Activeren wanneer verbonden met stroom";
"Automatically activates when the Mac is connected to AC power, and deactivates when it switches to battery." = "Activeert automatisch wanneer de Mac is aangesloten op wisselstroom en deactiveert wanneer overgeschakeld wordt naar batterij.";

/* Lid-close sudoers alert */
"Administrator Access Required" = "Beheerderstoegang vereist";
"Enabling this option creates a system file that allows Caffeine Revanced to prevent lid-close sleep without asking for your password each time. Disabling will remove the file automatically." = "Het inschakelen van deze optie maakt een systeembestand aan waarmee Caffeine Revanced kan voorkomen dat het systeem in slaapstand gaat bij het sluiten van het deksel, zonder elke keer om een wachtwoord te vragen. Bij uitschakelen wordt het bestand automatisch verwijderd.";
"Continue" = "Doorgaan";
"Keeps the Mac awake when the lid is closed while Caffeine Revanced is running. Requires one-time administrator authorization." = "Houdt de Mac actief wanneer het deksel gesloten is terwijl Caffeine Revanced actief is. Vereist eenmalige beheerdersautorisatie.";

/* External display activation */
"Activate when an external display is connected" = "Activeren wanneer een extern beeldscherm wordt aangesloten";
"Automatically activates when an external display is connected, and deactivates when disconnected." = "Activeert automatisch wanneer een extern beeldscherm wordt aangesloten en deactiveert bij loskoppelen.";

/* Audio activation */
"Activate when audio is playing" = "Activeren wanneer audio wordt afgespeeld";
"Automatically activates while audio is playing through the default output device." = "Activeert automatisch terwijl audio wordt afgespeeld via het standaard uitvoerapparaat.";

/* Inactivity deactivation */
"Deactivate after inactivity" = "Deactiveren na inactiviteit";
"Automatically deactivates after the specified period of user inactivity (no keyboard or mouse input)." = "Deactiveert automatisch na de opgegeven periode van gebruikersinactiviteit (geen toetsenbord- of muisinvoer).";

